digraph OceanFish_Architecture {
    rankdir=TB
    compound=true
    splines=ortho
    nodesep=0.5
    ranksep=1.0

    node [shape=box, style="rounded,filled", fillcolor="#E3F2FD", fontsize=11, fontname="Arial"]
    edge [arrowsize=0.8, penwidth=1.5]

    subgraph cluster_main {
        label="Главная программа (Kotlin Multiplatform)"
        labeljust="l"
        fontsize=13
        fontname="Arial Bold"
        fillcolor="#BBDEFB"
        style="rounded,filled"

        UI [label="Пользовательский интерфейс\nKotlin/Compose Multiplatform", fillcolor="#81C4FF"]
        Core [label="Общая бизнес-логика\nKMP shared module", fillcolor="#81C4FF"]
        Gateway [label="API Gateway / Orchestrator", fillcolor="#81C4FF"]

        UI -> Core [style=bold]
        Core -> Gateway [style=bold]
    }
    subgraph cluster_micro {
        label="Микросервисы"
        labeljust="l"
        fontsize=13
        fontname="Arial Bold"
        fillcolor="#C8E6C9"
        style="rounded,filled"

        HR [label="Подсистема Отдела\nкадрового учёта"]
        VED [label="Подсистема Внешнеэкономической\nдеятельности"]
        Monitoring [label="Подсистема Мониторинга\nсудов"]
        Fishing [label="Подсистема Промышленного\nрыболовства"]
        User [label="Интеграция всех микросервисов —\nинтеграция", fillcolor="#FFCC80"]
    }

    Docker [label="Docker Compose", shape=ellipse, fillcolor="#FFF9C4", fontsize=12, style="filled"]

    Gateway -> HR
    Gateway -> VED
    Gateway -> Monitoring
    Gateway -> Fishing
    Gateway -> User

    HR -> Docker
    VED -> Docker
    Monitoring -> Docker
    Fishing -> Docker
    User -> Docker

    { rank=same; HR; VED; Monitoring; Fishing; User }
}